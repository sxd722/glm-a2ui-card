{
  "schemaVersion": "1.0.0",
  "appId": "com.example.todoassistant",
  "skillId": "todo-assistant",
  "title": "Todo Assistant",
  "summary": "Capture, prioritize, and complete daily tasks with minimal typing.",
  "homePattern": "home",
  "palette": {
    "primary": "#2563EB",
    "secondary": "#1E40AF",
    "accent": "#F59E0B",
    "surface": "#F3F4F6",
    "text": "#111827"
  },
  "runtimePrompt": "You are a Todo Assistant. Help users add tasks by suggesting priority and due dates. Prioritize quick taps over typing. When a task is confirmed, add it to the list. When a user marks a task complete, remove it or move it to a completed section.",
  "dynamicSlots": [],
  "componentRecipes": [
    {
      "name": "TaskListItem",
      "nodeKind": "resultList",
      "description": "A list item showing task title, priority, and a complete button."
    }
  ],
  "nestedApp": {
    "pages": [
      {
        "id": "home",
        "title": "My Tasks",
        "subtitle": "Stay on top of your day",
        "nodes": [
          {
            "id": "home_header",
            "kind": "heroMedia",
            "title": "Todo Assistant",
            "text": "Capture, prioritize, complete",
            "binding": "",
            "assetId": "",
            "items": [],
            "actions": [],
            "tone": "neutral"
          },
          {
            "id": "active_tasks",
            "kind": "resultList",
            "title": "Active Tasks",
            "text": "Tap to view details",
            "binding": "tasks",
            "assetId": "",
            "items": [],
            "actions": [
              {
                "id": "complete_task",
                "label": "Complete",
                "kind": "invokeAgent",
                "targetPageId": "home",
                "payload": { "tool": "Mark complete" },
                "handling": "localThenAgent"
              }
            ],
            "tone": "neutral"
          },
          {
            "id": "add_task_bar",
            "kind": "actionBar",
            "title": "",
            "text": "",
            "binding": "",
            "assetId": "",
            "items": [],
            "actions": [
              {
                "id": "go_capture",
                "label": "Add Task",
                "kind": "navigate",
                "targetPageId": "capture",
                "payload": {},
                "handling": "local"
              }
            ],
            "tone": "primary"
          }
        ]
      },
      {
        "id": "capture",
        "title": "New Task",
        "subtitle": "What needs to be done?",
        "nodes": [
          {
            "id": "capture_input",
            "kind": "formField",
            "title": "Task Title",
            "text": "Enter your task here",
            "binding": "taskTitle",
            "assetId": "",
            "items": [],
            "actions": [],
            "tone": "neutral"
          },
          {
            "id": "capture_action_bar",
            "kind": "actionBar",
            "title": "",
            "text": "",
            "binding": "",
            "assetId": "",
            "items": [],
            "actions": [
              {
                "id": "get_suggestions",
                "label": "Suggest Details",
                "kind": "navigate",
                "targetPageId": "suggest",
                "payload": {},
                "handling": "agent"
              }
            ],
            "tone": "primary"
          }
        ]
      },
      {
        "id": "suggest",
        "title": "Quick Confirm",
        "subtitle": "Here is what I suggest",
        "nodes": [
          {
            "id": "suggest_panel",
            "kind": "glassPanel",
            "title": "Task Details",
            "text": "Adjust if needed",
            "binding": "",
            "assetId": "",
            "items": [],
            "actions": [],
            "tone": "neutral"
          },
          {
            "id": "priority_chips",
            "kind": "choiceChips",
            "title": "Priority",
            "text": "Tap to change",
            "binding": "priority",
            "assetId": "",
            "items": ["low", "medium", "high"],
            "actions": [],
            "tone": "neutral"
          },
          {
            "id": "due_date_chips",
            "kind": "choiceChips",
            "title": "Due Date",
            "text": "Tap to change",
            "binding": "dueDate",
            "assetId": "",
            "items": ["Today", "Tomorrow", "Next Week"],
            "actions": [],
            "tone": "neutral"
          },
          {
            "id": "confirm_action_bar",
            "kind": "actionBar",
            "title": "",
            "text": "",
            "binding": "",
            "assetId": "",
            "items": [],
            "actions": [
              {
                "id": "confirm_add",
                "label": "Confirm & Add",
                "kind": "invokeAgent",
                "targetPageId": "home",
                "payload": { "tool": "Add task" },
                "handling": "localThenAgent"
              }
            ],
            "tone": "positive"
          }
        ]
      }
    ]
  }
}
