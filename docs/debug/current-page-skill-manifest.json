{
  "schemaVersion": "1.0.0",
  "skillId": "todo-assistant",
  "skillName": "Todo Assistant",
  "version": "1.0.0",
  "description": "Help a user capture, prioritize, and complete daily tasks with minimal typing.",
  "goals": [
    "Help a user capture, prioritize, and complete daily tasks with minimal typing."
  ],
  "inputFields": [
    { "id": "taskTitle", "label": "Task title", "kind": "text", "required": true, "options": [] },
    { "id": "priority", "label": "Priority", "kind": "enum", "required": false, "options": ["low", "medium", "high"] },
    { "id": "dueDate", "label": "Due date", "kind": "date", "required": false, "options": [] }
  ],
  "outputFields": [
    { "id": "prioritizedTaskList", "label": "Prioritized task list", "kind": "list" },
    { "id": "nextRecommendedAction", "label": "Next recommended action", "kind": "text" }
  ],
  "workflow": [
    "Capture a task.",
    "Suggest a priority and due date.",
    "Ask the user to confirm with one tap.",
    "Track completion."
  ],
  "decisionPoints": [
    { "id": "confirmSuggestion", "description": "User confirms or edits the suggested priority and due date.", "options": ["confirm", "edit"] }
  ],
  "toolContracts": [
    { "name": "Add task", "description": "Adds a new task to the todo list.", "adapterId": "", "inputFields": [{ "id": "taskTitle", "label": "Task title", "kind": "text", "required": true, "options": [] }, { "id": "priority", "label": "Priority", "kind": "enum", "required": false, "options": ["low", "medium", "high"] }, { "id": "dueDate", "label": "Due date", "kind": "date", "required": false, "options": [] }], "outputFields": [{ "id": "taskId", "label": "Task ID", "kind": "text" }], "allowedOrigins": [], "credentialRef": "", "confirmation": false, "implemented": false },
    { "name": "Change priority", "description": "Updates the priority of an existing task.", "adapterId": "", "inputFields": [{ "id": "taskId", "label": "Task ID", "kind": "text", "required": true, "options": [] }, { "id": "priority", "label": "Priority", "kind": "enum", "required": true, "options": ["low", "medium", "high"] }], "outputFields": [], "allowedOrigins": [], "credentialRef": "", "confirmation": false, "implemented": false },
    { "name": "Mark complete", "description": "Marks an existing task as completed.", "adapterId": "", "inputFields": [{ "id": "taskId", "label": "Task ID", "kind": "text", "required": true, "options": [] }], "outputFields": [], "allowedOrigins": [], "credentialRef": "", "confirmation": false, "implemented": false }
  ],
  "permissions": ["tasks:read", "tasks:write"],
  "constraints": [
    "Requires minimal typing from the user.",
    "Must suggest priority and due date before asking for confirmation.",
    "Confirmation must be doable with one tap."
  ],
  "examples": [
    {
      "input": { "taskTitle": "Buy groceries" },
      "output": {
        "prioritizedTaskList": ["Buy groceries (Medium, Due Tomorrow)"],
        "nextRecommendedAction": "Confirm task creation."
      }
    }
  ]
}
